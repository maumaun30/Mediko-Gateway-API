DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

BREVO_USER=your_brevo_email
BREVO_PASS=your_brevo_smtp_key

MAIL_FROM=no-reply@mediko.ph
ADMIN_EMAIL=admin@mediko.ph
ADMIN_CC=manager@mediko.ph,billing@mediko.ph
ADMIN_API_KEY=xxxxxxx
ADMIN_DASHBOARD_PASSWORD=
DASHBOARD_JWT_SECRET=xxxxx

ALLOWED_ORIGINS='https://store.mediko.ph,https://mediko.ph'

# Shopify Admin API (required for auto-generating discount codes on approval)
# Custom app scopes needed (GraphQL Admin API): read_customers, write_customers, write_discounts
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2026-04
DISCOUNT_PERCENTAGE=20

PORT=3001

# Set to "true" to disable rate limiter, time-trap, and submission cooldown
# on form endpoints (apply / contact / returns). Local + staging only — NEVER in prod.
TESTING_MODE=false